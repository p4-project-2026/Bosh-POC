Backup Dir is "/local/backup".
Dir is "/path/directory".
# Date Prefix (YYYY-MM-DD)
Date Prefix is now.

make new folder Backup Dir in here.
go to Backup Dir otherwise quit.

say "Copy files from @Dir to @Backup Dir". 

# Copy files
copy from Dir to Backup Dir.

for each Current File in here:
    if Current File equals file
        rename Current File to "@Date Prefix_@Current File"

say "Cleaning files older than 7 days..."

# Delete files older than 7 days
for all Current File in here:
    if Current File equals file and Current File age greater than 7 days:
        delete Current File

say "Done"